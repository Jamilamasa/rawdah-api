PORT=8080
ENV=production
ALLOWED_ORIGINS=https://app.rawdah.app,https://kids.rawdah.app,http://localhost:3001,http://localhost:3002

DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
AUTO_MIGRATE=true

JWT_ACCESS_SECRET=<min-64-char-random-string>
JWT_REFRESH_SECRET=<different-min-64-char-random-string>
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
CHILD_TOKEN_TTL=4h

R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-access-key>
R2_SECRET_ACCESS_KEY=<r2-secret-key>
R2_BUCKET=rawdah-assets
PRESIGN_EXPIRES_SECONDS=600

BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=hello@rawdah.app
BREVO_SENDER_NAME=Rawdah
ADULT_PLATFORM_URL=https://app.rawdah.app
KIDS_PLATFORM_URL=https://kids.rawdah.app

OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemma-2-9b-it
OPENROUTER_FALLBACK_MODEL=mistralai/mistral-7b-instruct

DUA_COMPANION_BASE_URL=https://dua-companion-api.onrender.com
DUA_COMPANION_TIMEOUT=20s

VAPID_PUBLIC_KEY=<vapid-public>
VAPID_PRIVATE_KEY=<vapid-private>
VAPID_SUBJECT=mailto:hello@rawdah.app

CRON_SECRET=<min-64-char-random-string>
